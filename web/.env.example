# Copy to .env.local and fill in. Real values are NEVER committed (.env* is
# gitignored; only this template is tracked). In production, set these in the
# Vercel project (Settings → Environment Variables, or `vercel env add`).

# ----------------------------------------------------------------------------
# Server-side secrets (never shipped to the browser)
# ----------------------------------------------------------------------------

# OpenRouter API key for the AI chat agent (/api/chat). Spends money per call —
# the primary abuse target, hence the strict Firewall rule below.
OPENROUTER_API_KEY=

# Blockberry API key for the Sui data proxies (coin / account / holder routes).
BLOCKBERRY_API_KEY=

# HMAC secret backing the API session cookie + per-request signature
# (src/proxy.ts). Must be 16+ chars; use 32+ bytes of randomness:
#   openssl rand -hex 32
# REQUIRED in production: when unset, /api/* is refused outright. In dev, an
# unset value DISABLES protection (with a console warning) so the app still runs.
API_SIGNING_SECRET=

# Extra hostnames allowed to call /api/* beyond the deployment's own host (which
# is always allowed). Comma-separated, scheme optional. Usually leave blank;
# set it for custom domains / preview hosts. Example:
#   ALLOWED_ORIGINS=app.example.com,staging.example.com
ALLOWED_ORIGINS=

# ----------------------------------------------------------------------------
# Public (NEXT_PUBLIC_*) — inlined into the browser bundle, NOT secret
# ----------------------------------------------------------------------------

# Canonical public site origin (optional). Used for absolute URLs.
NEXT_PUBLIC_SITE_URL=

# ----------------------------------------------------------------------------
# Vercel Firewall — rate limiting (configured in the dashboard, NOT in code)
# ----------------------------------------------------------------------------
# This is the workhorse against spam / cost blow-ups and caps any attacker who
# lifts a live session. Configure in Vercel → project → Firewall → Rate Limiting:
#   - Path  /api/*     →  ~60 requests / minute / IP
#   - Path  /api/chat  →  ~10 requests / minute / IP   (stricter; spends money)
